<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/overlay_background"
    android:padding="8dp">

    <!-- Drag Header -->
    <LinearLayout
        android:id="@+id/editor_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="6dp"
        android:gravity="center_vertical"
        android:background="@color/primary_dark">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cấu hình Hành động"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_marginTop="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="4dp">

            <!-- Timing Fields -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Thời gian chạy &amp; Delay"
                android:textColor="#FF42A5F5"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Duration (ms)"
                        android:textColor="#88FFFFFF"
                        android:textSize="8sp" />
                    <EditText
                        android:id="@+id/et_duration"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:background="#22FFFFFF"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:padding="4dp"
                        android:inputType="number"
                        android:text="100"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delay sau (ms)"
                        android:textColor="#88FFFFFF"
                        android:textSize="8sp" />
                    <EditText
                        android:id="@+id/et_delay"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:background="#22FFFFFF"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:padding="4dp"
                        android:inputType="number"
                        android:text="1000"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Condition Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Điều kiện nhận diện hình ảnh"
                android:textColor="#FF42A5F5"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

            <Spinner
                android:id="@+id/sp_condition_type"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:background="#33FFFFFF"
                android:layout_marginTop="2dp" />

            <Button
                android:id="@+id/btn_crop_template"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:text="📸 Cắt ảnh mẫu từ màn hình"
                android:textSize="10sp"
                android:textAllCaps="false"
                android:background="@color/overlay_btn"
                android:textColor="#FFFFFF"
                android:layout_marginTop="4dp"/>

            <Button
                android:id="@+id/btn_select_search_region"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:text="📐 Chọn khoảng nhận diện (OCR/Ảnh)"
                android:textSize="10sp"
                android:textAllCaps="false"
                android:background="@color/overlay_btn"
                android:textColor="#FFFFFF"
                android:layout_marginTop="4dp"/>

            <!-- Region Bounds Summary -->
            <TextView
                android:id="@+id/tv_region_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Khung quét: L:0%, T:0%, R:100%, B:100%"
                android:textColor="#FFFFD54F"
                android:textSize="9sp"
                android:layout_marginTop="4dp"
                android:textStyle="bold"/>

            <!-- Hidden input fields for backwards compatibility -->
            <LinearLayout
                android:id="@+id/layout_hidden_regions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone">

                <EditText
                    android:id="@+id/et_region_l"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:text="0"/>
                <EditText
                    android:id="@+id/et_region_t"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:text="0"/>
                <EditText
                    android:id="@+id/et_region_r"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:text="100"/>
                <EditText
                    android:id="@+id/et_region_b"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:text="100"/>
            </LinearLayout>

            <!-- Image Condition Fields Group -->
            <LinearLayout
                android:id="@+id/layout_image_cond_fields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tv_image_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Trạng thái ảnh mẫu: Chưa có"
                    android:textColor="#FFFFD54F"
                    android:textSize="9sp" />

                <!-- Similarity Threshold -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Độ chính xác yêu cầu (0.1..1.0)"
                    android:textColor="#88FFFFFF"
                    android:textSize="8sp"
                    android:layout_marginTop="4dp"/>
                <EditText
                    android:id="@+id/et_threshold"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:background="#22FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:padding="2dp"
                    android:inputType="numberDecimal"
                    android:text="0.8"/>

                <CheckBox
                    android:id="@+id/cb_click_matched_image"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Chạm vào tâm ảnh tìm thấy (nếu có)"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:layout_marginTop="4dp"
                    android:buttonTint="#FF42A5F5"/>
            </LinearLayout>

            <!-- Number Condition Fields Group -->
            <LinearLayout
                android:id="@+id/layout_number_cond_fields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="4dp">

                <!-- Threshold Value for Numbers -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ngưỡng giá trị so sánh (số)"
                    android:textColor="#88FFFFFF"
                    android:textSize="8sp"
                    android:layout_marginTop="4dp"/>
                <EditText
                    android:id="@+id/et_condition_value"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:background="#22FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:padding="2dp"
                    android:inputType="numberDecimal"
                    android:text="400.0"/>
            </LinearLayout>

            <!-- Branch Jumps Group -->
            <LinearLayout
                android:id="@+id/layout_branch_jumps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Logic Rẽ Nhánh (Index hành động 1-indexed)"
                    android:textColor="#FF42A5F5"
                    android:textSize="10sp"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nhảy nếu ĐÚNG"
                            android:textColor="#88FFFFFF"
                            android:textSize="8sp" />
                        <EditText
                            android:id="@+id/et_true_jump"
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:background="#22FFFFFF"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:padding="4dp"
                            android:inputType="numberSigned"
                            android:text="-1"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="4dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nhảy nếu SAI"
                            android:textColor="#88FFFFFF"
                            android:textSize="8sp" />
                        <EditText
                            android:id="@+id/et_false_jump"
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:background="#22FFFFFF"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:padding="4dp"
                            android:inputType="numberSigned"
                            android:text="-1"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/btn_delete_action"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Xóa"
            android:textSize="11sp"
            android:background="@color/error"
            android:textColor="#FFFFFF"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btn_cancel_edit"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Hủy"
            android:textSize="11sp"
            android:background="#FF757575"
            android:textColor="#FFFFFF"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btn_save_edit"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Lưu"
            android:textSize="11sp"
            android:background="@color/success"
            android:textColor="#FFFFFF"
            android:textAllCaps="false" />
    </LinearLayout>

</LinearLayout>
